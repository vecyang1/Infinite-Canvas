# Copy this file to API/.env for local use.
# API/.env is ignored by git and must never be committed with real keys.

# Built-in/custom providers
COMFLY_API_KEY=
COMFLY_BASE_URL=https://ai.comfly.chat
MODELSCOPE_API_KEY=
MODELSCOPE_CHAT_MODELS=

# Custom providers created by scripts/configure_provider.py use:
# API_PROVIDER_<PROVIDER_ID>_KEY=
# Example for provider id "nano-banana":
API_PROVIDER_NANO_BANANA_KEY=

# Global defaults used when no provider-specific model is selected.
CHAT_MODEL=gpt-4o-mini
IMAGE_MODEL=gpt-image-2
IMAGE_MODELS=gpt-image-2
CHAT_MODELS=gpt-4o-mini
VIDEO_MODELS=veo3-fast

# Runtime limits and polling.
REQUEST_TIMEOUT=120
IMAGE_POLL_INTERVAL=2
IMAGE_TASK_TIMEOUT=120
APIMART_IMAGE_TASK_TIMEOUT=1800
APIMART_IMAGE_POLL_INTERVAL=5
APIMART_IMAGE_INITIAL_POLL_DELAY=10
VIDEO_POLL_TIMEOUT=1800
ONLINE_IMAGE_PROMPT_MAX_LENGTH=20000
VIDEO_PROMPT_MAX_LENGTH=4000
LLM_MESSAGE_MAX_LENGTH=20000

# ComfyUI local instances.
COMFYUI_INSTANCES=127.0.0.1:8188
